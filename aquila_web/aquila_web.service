[Unit]
Description=Uvicorn application service
After=network.target

[Service]
User=pi
Environment=PYTHONPATH=/home/pi/aquilla-main
WorkingDirectory=/home/pi/aquilla-main/aquila_web
ExecStart=/home/pi/aquilla-main/bin/uvicorn main:app --host 0.0.0.0 --port 8090
Restart=on-failure

[Install]
WantedBy=multi-user.target
