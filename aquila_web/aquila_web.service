[Unit]
Description=Uvicorn application service
After=network.target

[Service]
User=pi
Environment=AQ_SRC_BASEDIR=/home/pi/aquilla-main
WorkingDirectory=${AQ_SRC_BASEDIR}/aquila_web
ExecStart=${AQ_SRC_BASEDIR}/bin/uvicorn main:app --host 0.0.0.0 --port 8090
Restart=on-failure

[Install]
WantedBy=multi-user.target
