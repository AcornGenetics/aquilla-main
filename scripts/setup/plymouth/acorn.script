// Acorn boot splash — matches splash.html: white background, centered logo
// Background: white (#ffffff = 1.0, 1.0, 1.0)
Window.SetBackgroundTopColor(1.0, 1.0, 1.0);
Window.SetBackgroundBottomColor(1.0, 1.0, 1.0);

logo_image = Image("acorn_logo.png");

logo_sprite = Sprite(logo_image);
logo_sprite.SetX(Window.GetWidth()  / 2 - logo_image.GetWidth()  / 2);
logo_sprite.SetY(Window.GetHeight() / 2 - logo_image.GetHeight() / 2 - 40);
logo_sprite.SetOpacity(1);
