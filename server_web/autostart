xset s off
xset s noblank
xset -dpms

xrandr --output HDMI-1 --mode 1024x768 --rate 60 --rotate right

setxkbmap -option terminate:ctrl_alt_bksp

unclutter -idle 0.5 &

sleep 3
python3 /home/pi/kiosk.py &


